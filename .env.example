# CraftDock — copy to .env and customize

JWT_SECRET=generate-a-64-char-random-string
SESSION_SECRET=generate-another-random-string
CSRF_SECRET=generate-csrf-secret

DATABASE_URL=postgresql://craftdock:craftdock@localhost:5432/craftdock

# Panel URL (your LAN IP) — required for CORS when using ports 3000 + 4000
FRONTEND_URL=http://192.168.1.170:3000

# Optional override; leave empty to auto-use http://<same-host>:4000 in the browser
NEXT_PUBLIC_API_URL=

# HTTP on LAN — keep false unless you use HTTPS
COOKIE_SECURE=false

# Optional — Modrinth works without a key (default). CurseForge: https://console.curseforge.com/
CURSEFORGE_API_KEY=

ADMIN_EMAIL=admin@craftdock.local
ADMIN_PASSWORD=changeme123
ADMIN_USERNAME=admin

DATA_DIR=/var/lib/craftdock/servers
BACKUP_DIR=/var/lib/craftdock/backups

# Rate limit applies to POST/PUT/PATCH/DELETE only (GET polling is excluded)
# RATE_LIMIT_MAX=500
# RATE_LIMIT_WINDOW_MS=900000
