# CraftDock — copy to .env and customize

JWT_SECRET=generate-a-64-char-random-string
SESSION_SECRET=generate-another-random-string
CSRF_SECRET=generate-csrf-secret

DATABASE_URL=postgresql://craftdock:craftdock@localhost:5432/craftdock

FRONTEND_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:4000

CURSEFORGE_API_KEY=

ADMIN_EMAIL=admin@localhost
ADMIN_PASSWORD=changeme123
ADMIN_USERNAME=admin

DATA_DIR=/var/lib/craftdock/servers
BACKUP_DIR=/var/lib/craftdock/backups
