# CraftDock Backend Configuration
NODE_ENV=development
PORT=4000
HOST=0.0.0.0

# Database
DATABASE_URL=postgresql://craftdock:craftdock@localhost:5432/craftdock

# Security
JWT_SECRET=change-me-to-a-long-random-string-at-least-32-chars
JWT_EXPIRES_IN=7d
SESSION_SECRET=change-me-session-secret
CSRF_SECRET=change-me-csrf-secret
BCRYPT_ROUNDS=12

# Paths (absolute on production Ubuntu server)
DATA_DIR=/var/lib/craftdock/servers
BACKUP_DIR=/var/lib/craftdock/backups
JAVA_HOME=/usr/lib/jvm/java-21-openjdk-amd64

# CurseForge API (get key at https://console.curseforge.com/)
CURSEFORGE_API_KEY=

# Docker runtime (optional)
DOCKER_ENABLED=true
DOCKER_NETWORK=craftdock-net
DOCKER_IMAGE=itzg/minecraft-server:latest

# Rate limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# Frontend URL (CORS)
FRONTEND_URL=http://localhost:3000

# First admin (seeded on first run if no users exist)
ADMIN_EMAIL=admin@localhost
ADMIN_PASSWORD=changeme123
ADMIN_USERNAME=admin

# Backup retention
BACKUP_RETENTION_DAYS=14
BACKUP_CRON=0 3 * * *

# Multi-node (future)
NODE_ID=local
